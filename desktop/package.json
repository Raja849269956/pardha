{
  "name": "pardha-desktop",
  "version": "0.1.0",
  "description": "Desktop app for Pardha",
  "main": "src/main.js",
  "scripts": {
    "dev": "concurrently \"npm run dev:webpack\" \"wait-on http://localhost:3000 && electron .\"",
    "dev:webpack": "webpack serve --mode development",
    "build": "webpack --mode production",
    "start": "electron .",
    "pack": "electron-builder",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.24.0",
    "dotenv": "16.4.5"
  },
  "devDependencies": {
    "@babel/core": "^7.24.7",
    "@babel/preset-env": "^7.24.7",
    "@babel/preset-react": "^7.24.7",
    "babel-loader": "^9.1.3",
    "concurrently": "^8.2.2",
    "css-loader": "^7.1.2",
    "electron": "31.0.2",
    "electron-builder": "24.13.3",
    "html-webpack-plugin": "5.6.0",
    "style-loader": "4.0.0",
    "wait-on": "7.2.0",
    "webpack": "5.92.1",
    "webpack-cli": "5.1.4",
    "webpack-dev-server": "4.15.1"
  },
  "build": {
    "appId": "com.pardha.app",
    "productName": "Pardha",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/main.js",
      "src/preload.js",
      "build/**/*",
      ".env"
    ],
    "mac": {
      "target": "dmg"
    },
    "win": {
      "target": "nsis"
    }
  }
}
