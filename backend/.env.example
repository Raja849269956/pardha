# SQLite for quick local testing; switch to Postgres for production:
DATABASE_URL=sqlite:///./interview_copilot.db
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/interview_copilot
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-...

# ASR provider (deepgram, assemblyai, openai)
ASR_PROVIDER=deepgram
DEEPGRAM_API_KEY=...
ASSEMBLYAI_API_KEY=...

# LLM provider (openai, anthropic)
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# Set to true to test without AI API keys
MOCK_ASR=false
MOCK_LLM=false

# CORS
# For local desktop dev:
FRONTEND_ORIGIN=http://localhost:3000
# For production desktop apps (Electron loads from file://), allow all origins:
# FRONTEND_ORIGIN=*
